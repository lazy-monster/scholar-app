<?xml version="1.0" encoding="utf-8"?>
<!-- Shared pieces merged into every app module: permissions, the home-screen widget receivers,
     and the update FileProvider. Per-app bits (application name/icon/label/theme, the launcher
     activity) live in each app module's manifest. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- In-app updates: fetch the latest release and install the downloaded APK. Used only when
         the user taps "Check for updates" in Settings; the app is otherwise fully offline. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application>

        <receiver
            android:name="com.tianxian.core.widget.CharacterWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_character_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/character_widget_info" />
        </receiver>

        <receiver
            android:name="com.tianxian.core.widget.StatusWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_status_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/status_widget_info" />
        </receiver>

        <!-- Shares a downloaded update APK with the system package installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
